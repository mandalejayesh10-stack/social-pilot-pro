# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Set these in Railway (backend) and Vercel (frontend)
# ============================================================

# ── DATABASE (Railway PostgreSQL — auto-set by Railway) ──────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── AUTH ─────────────────────────────────────────────────────
JWT_SECRET=generate_64_char_random_string_here
JWT_EXPIRY=7d
TOKEN_ENCRYPTION_KEY=generate_64_char_hex_string_here

# ── URLS ─────────────────────────────────────────────────────
# Backend Railway URL (set after Railway deploy)
BACKEND_INTERNAL_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://your-app.vercel.app

# ── STORAGE (use Supabase for production — no local files) ───
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_BUCKET=socialpilot-media

# ── OAUTH ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
META_API_VERSION=v21.0

# ── STRIPE ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SIGNING_KEY=whsec_...

# ── FRONTEND (Vercel env vars — prefix NEXT_PUBLIC_) ─────────
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app
BACKEND_PROXY_URL=https://your-backend.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── MISC ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

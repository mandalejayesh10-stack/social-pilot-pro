{
  "name": "socialpilot-pro",
  "version": "1.0.0",
  "description": "SocialPilot Pro — Production-grade Social Media SaaS Platform",
  "main": "index.js",
  "license": "AGPL-3.0",
  "keywords": ["social-media", "saas", "analytics", "scheduler"],
  "author": "",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "setup": "node scripts/setup.js",
    "setup:db": "node scripts/setup-db.js",
    "setup:stripe": "node scripts/setup-stripe.js",
    "check:env": "node scripts/check-env.js",
    "start:db": "powershell -ExecutionPolicy Bypass -File scripts/start-db.ps1",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "tunnel": "C:\\ngrok\\ngrok.exe start --config ngrok.yml backend",
    "tunnel:status": "C:\\ngrok\\ngrok.exe tunnels --config ngrok.yml",
    "dev": "pnpm run --filter ./apps/orchestrator --filter ./apps/backend --filter ./apps/frontend --parallel dev",
    "dev:backend": "pnpm run --filter ./apps/backend --filter ./apps/frontend --parallel dev",
    "dev:backend:only": "pnpm --filter @socialpilot/backend run dev",
    "dev:frontend:only": "pnpm --filter @socialpilot/frontend run dev",
    "dev:orchestrator": "pnpm --filter @socialpilot/orchestrator run dev",
    "build": "pnpm -r --workspace-concurrency=1 --filter ./apps/frontend --filter ./apps/backend --filter ./apps/orchestrator run build",
    "build:backend": "pnpm --filter ./apps/backend run build",
    "build:frontend": "pnpm --filter ./apps/frontend run build",
    "build:orchestrator": "pnpm --filter ./apps/orchestrator run build",
    "start:prod:backend": "pnpm --filter ./apps/backend run start",
    "start:prod:frontend": "pnpm --filter ./apps/frontend run start",
    "start:prod:orchestrator": "pnpm --filter ./apps/orchestrator run start",
    "dev:docker": "docker compose -f ./docker-compose.dev.yaml up -d",
    "prisma-generate": "pnpm dlx prisma@6.5.0 generate --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-db-push": "pnpm dlx prisma@6.5.0 db push --accept-data-loss --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-db-pull": "pnpm dlx prisma@6.5.0 db pull --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-migrate": "pnpm dlx prisma@6.5.0 migrate dev --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-migrate-deploy": "pnpm dlx prisma@6.5.0 migrate deploy --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-reset": "pnpm dlx prisma@6.5.0 db push --force-reset --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "prisma-seed": "ts-node -r dotenv/config -r tsconfig-paths/register libraries/nestjs-libraries/src/database/prisma/seed.ts",
    "prisma-studio": "pnpm dlx prisma@6.5.0 studio --schema ./libraries/nestjs-libraries/src/database/prisma/schema.prisma",
    "postinstall": "pnpm run prisma-generate",
    "test": "jest --coverage --detectOpenHandles --reporters=default --reporters=jest-junit",
    "dev:stripe": "pnpm dlx concurrently \"stripe listen --forward-to localhost:3000/stripe\" \"pnpm run dev\""
  },
  "dependencies": {
    "@ag-ui/mastra": "^1.0.1",
